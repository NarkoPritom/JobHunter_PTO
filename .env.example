# Telegram — create a bot via @BotFather, then message it once and use
# https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat id
TELEGRAM_BOT_TOKEN=123456:your-bot-token
TELEGRAM_OWNER_CHAT_ID=123456789

# Anthropic Claude API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# HeadHunter — only needed if you want the bot to submit responses for you.
# Search works fine without these two.
# Get via https://dev.hh.ru (register an app, run OAuth flow once manually)
HH_ACCESS_TOKEN=
HH_RESUME_ID=
HH_AREA_ID=1

# SuperJob — optional, https://api.superjob.ru
SUPERJOB_API_KEY=
SUPERJOB_LOGIN_TOKEN=

# App behaviour
SEARCH_INTERVAL_MINUTES=30
MIN_MATCH_SCORE_TO_NOTIFY=60
DATABASE_URL=sqlite+aiosqlite:///./jobhunter.db
LOG_LEVEL=INFO
